{
  "$schema": "https://alirezanet.github.io/Husky.Net/schema.json",
  "tasks": [
    {
      "name": "format code (whitespace)",
      "group": "pre-commit",
      "include": ["**/*.cs"],
      "command": "dotnet",
      "args": [ "format", "whitespace", "--include", "${staged}" ],
      "staged": true
    },
    {
      "name": "format code (style)",
      "group": "pre-commit",
      "include": ["**/*.cs"],
      "command": "dotnet",
      "args": [ "format", "style", "--include", "${staged}" ],
      "staged": true
    }
  ]
}
