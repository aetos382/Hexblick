<hw:BaseWindow
  x:Class="Hexblick.UI.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:i="using:Microsoft.Xaml.Interactivity"
  xmlns:hui="using:Hexblick.UI"
  xmlns:hb="using:Hexblick.Behaviors"
  xmlns:hw="using:Hexblick.Windowing"
  mc:Ignorable="d"
  Title="Hexblick">

  <Window.SystemBackdrop>
    <MicaBackdrop />
  </Window.SystemBackdrop>

  <Page>

    <i:Interaction.Behaviors>
      <hb:FileOpenPickerBehavior/>
    </i:Interaction.Behaviors>

    <StackPanel>

      <MenuBar>
        <MenuBarItem x:Uid="MenuFile" AccessKey="F">
          <MenuFlyoutItem x:Uid="MenuFileNew" AccessKey="N" Command="{x:Bind ViewModel.NewDocumentCommand}"/>
          <MenuFlyoutItem x:Uid="MenuFileOpen" Command="{x:Bind OpenFileCommand}"/>
          <MenuFlyoutSeparator/>
          <MenuFlyoutItem x:Uid="MenuFileSave" AccessKey="S" Command="{x:Bind ViewModel.SaveFileCommand}" CommandParameter="{x:Bind ViewModel.ActiveDocument.Value, Mode=OneWay}">
            <MenuFlyoutItem.KeyboardAccelerators>
              <KeyboardAccelerator Key="S" Modifiers="Control"/>
            </MenuFlyoutItem.KeyboardAccelerators>
          </MenuFlyoutItem>
          <MenuFlyoutItem Text="Save As"/>
          <MenuFlyoutItem Text="Save All"/>
          <MenuFlyoutSeparator/>
          <MenuFlyoutItem Text="Recently used files"/>
          <MenuFlyoutSeparator/>
          <MenuFlyoutItem Text="Close"/>
          <MenuFlyoutItem Text="Close All"/>
          <MenuFlyoutItem Text="Close Unmodified"/>
          <MenuFlyoutSeparator/>
          <MenuFlyoutItem Text="Exit" Command="{x:Bind ExitCommand}">
            <MenuFlyoutItem.KeyboardAccelerators>
              <KeyboardAccelerator Key="F4" Modifiers="Menu"/>
            </MenuFlyoutItem.KeyboardAccelerators>
          </MenuFlyoutItem>
        </MenuBarItem>
      </MenuBar>

      <TabView
        x:Name="TabView"
        HorizontalAlignment="Stretch"
        VerticalAlignment="Stretch"
        IsAddTabButtonVisible="False"
        TabItemsSource="{x:Bind ViewModel.EditorViewModels}">

        <i:Interaction.Behaviors>
          <i:EventTriggerBehavior EventName="TabItemsChanged">
            <i:InvokeCommandAction Command="{x:Bind TabViewTabItemsChangedCommand}"/>
          </i:EventTriggerBehavior>
          <i:EventTriggerBehavior EventName="SelectionChanged">
            <i:InvokeCommandAction Command="{x:Bind TabViewSelectionChangedCommand}"/>
          </i:EventTriggerBehavior>
          <i:EventTriggerBehavior EventName="TabCloseRequested">
            <i:InvokeCommandAction Command="{x:Bind TabViewTabCloseCommand}"/>
          </i:EventTriggerBehavior>
        </i:Interaction.Behaviors>

        <TabView.TabItemTemplate>
          <DataTemplate x:DataType="hui:EditorControlViewModel">
            <TabViewItem IsClosable="true">
              <TabViewItem.HeaderTemplate>
                <DataTemplate x:DataType="hui:EditorControlViewModel">
                  <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{x:Bind Title.Value, Mode=OneWay}"/>
                    <TextBlock Text=" *" Visibility="{x:Bind IsDirty.Value, Mode=OneWay}"/>
                  </StackPanel>
                </DataTemplate>
              </TabViewItem.HeaderTemplate>
              <TabViewItem.Content>
                <hui:EditorControl ViewModel="{x:Bind}"/>
              </TabViewItem.Content>
            </TabViewItem>
          </DataTemplate>
        </TabView.TabItemTemplate>

      </TabView>

    </StackPanel>
  </Page>

</hw:BaseWindow>
