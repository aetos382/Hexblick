<Window
    x:Class="Hexblick.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:local="using:Hexblick"
    mc:Ignorable="d"
    Title="Hexblick">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <TabView
      HorizontalAlignment="Stretch"
      VerticalAlignment="Stretch"
      AddTabButtonCommand="{x:Bind ViewModel.AddTabButtonCommand}"
      TabCloseRequested="TabView_OnTabCloseRequested"
      TabItemsSource="{x:Bind ViewModel.TabItems}">

      <TabView.TabItemTemplate>
        <DataTemplate x:DataType="local:TabItemViewModel">
          <TabViewItem IsClosable="true">
            <TabViewItem.Content>
            </TabViewItem.Content>
          </TabViewItem>
        </DataTemplate>
      </TabView.TabItemTemplate>

    </TabView>
</Window>
